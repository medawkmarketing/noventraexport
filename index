<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Noventra Export | Digital Card</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
body{
  margin:0;
  font-family:'Segoe UI', Arial, sans-serif;
  background:linear-gradient(135deg,#0d47a1,#42a5f5);
}

.card{
  max-width:420px;
  margin:30px auto;
  background:#ffffff;
  padding:22px;
  border-radius:18px;
  box-shadow:0 15px 40px rgba(0,0,0,0.2);
  text-align:center;
}

.logo img{
  width:95px;
  margin-bottom:10px;
}

h2{
  margin:10px 0 5px;
  font-size:22px;
  color:#0d47a1;
}

.tagline{
  color:#333;
  font-size:14px;
  margin-bottom:18px;
}

.btn{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  margin:10px 0;
  padding:13px;
  background:linear-gradient(135deg,#0d47a1,#42a5f5);
  color:#fff;
  text-decoration:none;
  border-radius:10px;
  font-size:15px;
  font-weight:500;
  transition:0.3s;
}

.btn i{
  font-size:18px;
}

.btn:hover{
  transform:scale(1.03);
  box-shadow:0 6px 18px rgba(0,0,0,0.25);
}

hr{
  border:none;
  border-top:1px solid #ddd;
  margin:20px 0;
}

.section-title{
  font-weight:600;
  color:#0d47a1;
  margin-bottom:6px;
}

.address, .services, .description{
  font-size:14px;
  color:#333;
  line-height:1.6;
}

/* 🔥 Small Square-Round Social Icons */
.social-icons{
  display:flex;
  justify-content:center;
  gap:12px;
  margin-top:15px;
}

.social-icons a{
  width:40px;
  height:40px;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:10px;
  color:#fff;
  font-size:16px;
  transition:0.3s;
}

/* Brand Colors */
.facebook{ background:#1877f2; }
.instagram{ background:#e1306c; }
.linkedin{ background:#0a66c2; }

/* Hover Effect */
.social-icons a:hover{
  transform:translateY(-3px) scale(1.08);
  box-shadow:0 8px 18px rgba(0,0,0,0.25);
}
</style>
</head>

<body>

<div class="card">

  <div class="logo">
    <img src="NOVENTRA EXPORT.png" alt="Noventra Export">
  </div>

  <h2>Canevibe Bio Export</h2>
  <div class="tagline">Connecting Quality | Delivery Trust</div>

  <a class="btn" href="contact.vcf">
    <i class="fa-solid fa-address-card"></i> Save Contact
  </a>

  <a class="btn" href="tel:+919173376636">
    <i class="fa-solid fa-phone"></i> Call Now
  </a>

  <a class="btn" href="https://wa.me/919173376636" target="_blank">
    <i class="fa-brands fa-whatsapp"></i> WhatsApp
  </a>

  <a class="btn" href="mailto:info@noventraexport.com">
    <i class="fa-solid fa-envelope"></i> E-mail
  </a>

  <a class="btn" href="https://nocentraexport.com/" target="_blank">
    <i class="fa-solid fa-globe"></i> Website
  </a>

  <hr>

  <div class="section-title">About</div>
  <div class="description">
    is a global trading company dedicated to delivering high-quality products and seamless export-import solutions worldwide. With a focus on reliability, compliance, and customer satisfaction, the company helps businesses build strong international trade relationships through efficient sourcing, logistics management, and end-to-end export support.
  </div>

  <hr>

  <div class="section-title">Services</div>
  <div class="services">
    Connecting Quality | Delivery Trust
  </div>

  <!-- 🔥 Social Icons -->
  <div class="social-icons">
    <a class="facebook" href="https://www.facebook.com/profile.php?id=61590101535335" target="_blank">
      <i class="fa-brands fa-facebook-f"></i>
    </a>

    <a class="instagram" href="https://www.instagram.com/noventra_export?igsh=MzRydXJmbm54dDMw" target="_blank">
      <i class="fa-brands fa-instagram"></i>
    </a>

    <a class="linkedin" href="https://www.linkedin.com/company/123224076/admin/dashboard/" target="_blank">
      <i class="fa-brands fa-linkedin-in"></i>
    </a>
  </div>

</div>

</body>
</html>
